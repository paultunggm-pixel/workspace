# 阿里云 OSS 环境变量配置模板
# 复制此文件为 .env 并填入真实密钥（.env 已加入 .gitignore，不会提交）

# consistency-eval 存储桶（OSS 静态网站托管）
export OSS_ACCESS_KEY_ID="your_key_here"
export OSS_ACCESS_KEY_SECRET="your_secret_here"

# Souti 内部存储桶（封面图片 CDN）
export SOUTI_OSS_ACCESS_KEY_ID="your_key_here"
export SOUTI_OSS_ACCESS_KEY_SECRET="your_secret_here"
